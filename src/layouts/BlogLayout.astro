---
import MainLayout from './MainLayout.astro';
import Giscus from '../components/Giscus';
import '../styles/blog.css';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    author: string;
    tags: string[];
    image?: { url: string; alt: string };
    comments: boolean;
  };
}

const { frontmatter } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, comments } = frontmatter;

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout title={title} description={description}>
  <article class="article-container">
    <!-- Header -->
    <header class="article-header">
      <a href="/" class="back-link">
        ← Volver al inicio
      </a>
      <h1 class="article-title">{title}</h1>
      <p class="article-description">{description}</p>
      <div class="article-meta">
        <span>Por <strong>{author}</strong></span>
        <span>{formattedDate}</span>
        {updatedDate && <span>Actualizado: {formattedUpdatedDate}</span>}
      </div>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="article-content">
      <slot />
    </div>

    <!-- Giscus Comments -->
    <Giscus client:load enabled={comments} title={title} />
  </article>

  <style>
    .article-container {
      width: 100%;
      max-width: 48rem;
      margin-left: auto;
      margin-right: auto;
      padding: 2rem 1rem;
    }

    .article-header {
      margin-bottom: 2rem;
    }

    .back-link {
      color: var(--color-accent);
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
      margin-bottom: 1rem;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .article-title {
      font-size: 2.25rem;
      font-weight: bold;
      margin: 0 0 0.75rem 0;
    }

    .article-description {
      color: var(--color-text);
      opacity: 0.8;
      margin: 0 0 1rem 0;
      font-size: 1.125rem;
    }

    .article-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--color-text);
      opacity: 0.6;
      margin-bottom: 1rem;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .tag {
      display: inline-block;
      background-color: var(--color-border);
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .article-content {
      color: var(--color-text);
      margin-bottom: 3rem;
    }

    .article-content :global(h2),
    .article-content :global(h3),
    .article-content :global(h4) {
      color: var(--color-text);
      margin-top: 1.5em;
      margin-bottom: 0.5em;
    }

    .article-content :global(a) {
      color: var(--color-accent);
      text-decoration: none;
      border-bottom: 1px solid var(--color-accent);
    }

    .article-content :global(a:hover) {
      opacity: 0.8;
    }

    .article-content :global(code) {
      background-color: var(--color-border);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      font-size: 0.9em;
    }

    .article-content :global(pre) {
      background-color: var(--color-border);
      padding: 1em;
      border-radius: 6px;
      overflow-x: auto;
    }

    .article-content :global(blockquote) {
      border-left: 4px solid var(--color-accent);
      padding-left: 1em;
      opacity: 0.8;
    }

    .article-content :global(img) {
      border-radius: 8px;
      max-width: 100%;
      height: auto;
    }

    .article-content :global(table) {
      border-collapse: collapse;
      width: 100%;
      margin: 1em 0;
    }

    .article-content :global(table th),
    .article-content :global(table td) {
      border: 1px solid var(--color-border);
      padding: 0.75em;
      text-align: left;
    }

    .article-content :global(table th) {
      background-color: var(--color-border);
      font-weight: 600;
    }
  </style>
</MainLayout>
